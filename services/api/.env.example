XXX_ENVIRONMENT=development
XXX_DEBUG=false
XXX_ALLOWED_ORIGINS=["http://localhost:3000"]
XXX_DATABASE_URL=sqlite+aiosqlite:///./xxx-development.db
XXX_JWT_SIGNING_SECRET=development-only-jwt-secret-change-before-production
XXX_TOKEN_HASH_SECRET=development-only-token-secret-change-before-production
XXX_MFA_ENCRYPTION_SECRET=development-only-mfa-encryption-secret-change-before-production
XXX_MAX_ACTIVE_SESSIONS_PER_USER=10
XXX_REDIS_URL=redis://127.0.0.1:6379/0
XXX_ANALYSIS_STREAM_NAME=xxx:analysis
XXX_ANALYSIS_CONSUMER_GROUP=xxx-analysis-workers
XXX_ANALYSIS_LEASE_SECONDS=600
XXX_ANALYSIS_MAX_ATTEMPTS=3
XXX_ANALYSIS_VALIDATOR_COMMAND=xxx-analyzer
XXX_ANALYSIS_VALIDATOR_TIMEOUT_SECONDS=60
XXX_ANALYSIS_SANDBOX_MODE=process
XXX_ANALYSIS_BUBBLEWRAP_COMMAND=bwrap
XXX_STORAGE_ENDPOINT_URL=http://127.0.0.1:9000
XXX_STORAGE_REGION=us-east-1
XXX_STORAGE_BUCKET=xxx-private-models
XXX_STORAGE_ACCESS_KEY=development-minio
XXX_STORAGE_SECRET_KEY=development-minio-secret
XXX_PUBLIC_WEB_URL=http://localhost:3000
XXX_EMAIL_SENDER_ADDRESS=no-reply@example.com
XXX_EMAIL_SENDER_NAME=xxx
XXX_SMTP_HOST=127.0.0.1
XXX_SMTP_PORT=1025
XXX_SMTP_STARTTLS=false
XXX_SMTP_USE_TLS=false
